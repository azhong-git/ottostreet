# Server port
PORT=8420

# Default market data provider for all capabilities: polygon | tradier | mock
# "polygon" is the default and covers quotes, bars, and options chains (OI +
# greeks) with a single key. If POLYGON_API_KEY is unset the server falls back
# to "mock" (synthetic data, no keys) so it still boots.
PROVIDER=polygon

# Per-capability overrides — useful for mixing providers as more are added.
# QUOTES_PROVIDER=
# BARS_PROVIDER=
# OPTIONS_PROVIDER=

# Polygon.io (https://polygon.io) — get a free API key from the dashboard.
# The free "Basic" plan works: ONE key covers both stocks and options with
# delayed data at 5 calls/minute. No separate options subscription needed on
# the free tier. Paid plans (real-time) split stocks and options.
POLYGON_API_KEY=

# Tradier (alternative; free with a brokerage account, sandbox = delayed data)
# https://documentation.tradier.com/brokerage-api
TRADIER_TOKEN=
TRADIER_ENV=sandbox

# LLM (not used by the GEX skill; reserved for news/social skills)
OPENAI_API_KEY=

# SQLite database location (relative to apps/server)
DB_PATH=data/ottostreet.db

{
  "name": "ottostreet",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Open-source stock & options signal engine: watchlist-driven, skill-based signal sources, LLM-assisted analysis.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @ottostreet/server dev\" \"pnpm --filter @ottostreet/web dev\"",
    "dev:server": "pnpm --filter @ottostreet/server dev",
    "dev:web": "pnpm --filter @ottostreet/web dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
